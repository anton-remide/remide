# ============================================================
# RemiDe Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and NEVER committed.
#
# WHO NEEDS WHAT:
#   Frontend (Sasha): Only VITE_* vars (lines 12-13)
#   Backend (Anton):  All vars
#   Both:             NOTION_TOKEN (for Claude Code agent)
# ============================================================

# --- FRONTEND (required for all developers) ---

# Supabase client-side (public/anon key — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- BACKEND ONLY (Anton — parsers, workers, scripts) ---

# Supabase server-side (service role key — NEVER expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API — for QA Worker + Country Research Worker
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Parallel.ai API — for AI Workers (Monitor, Dataset, Enrich)
PARALLEL_API_KEY=your-parallel-key

# Firecrawl API — for LLM-powered web scraping (enrichment)
FIRECRAWL_API_KEY=fc-xxx

# Resend — email delivery (Supabase Auth SMTP)
RESEND_API_KEY=re_xxx

# --- SHARED (both developers, for Claude Code Notion integration) ---

# Notion API token — allows Claude Code agent to read/write KB, log tasks
# Create at: https://www.notion.so/my-integrations
# Must have access to the RemiDe workspace
NOTION_TOKEN=ntn_xxx

# Supabase Access Token — for CLI operations (DDL, migrations)
# Get at: https://supabase.com/dashboard/account/tokens → Generate new token
SUPABASE_ACCESS_TOKEN=sbat_xxx

# --- OPTIONAL FLAGS ---

# DRY_RUN=true          # Parsers: skip DB writes, just log
# FORCE_WRITE=true      # Parsers: ignore anomaly detection
# TELEGRAM_BOT_TOKEN=   # Telegram alerts (GitHub Actions only)
# TELEGRAM_CHAT_ID=     # Telegram alerts (GitHub Actions only)
# FCA_API_KEY=          # UK FCA Register API (optional, for gb-fca parser)
