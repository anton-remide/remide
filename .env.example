# Supabase (client-side, exposed to browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side, seed script only — NEVER commit real value)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API — for QA Worker + Country Research Worker
ANTHROPIC_API_KEY=your-anthropic-key

# Parallel.ai API — for AI Workers (Monitor, Dataset, Enrich)
PARALLEL_API_KEY=your-parallel-key

# Firecrawl API — for LLM-powered web scraping (enrichment)
FIRECRAWL_API_KEY=your-firecrawl-key
